{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/kafka/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/kafka/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/kafka",
  "projects": {
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "dashboard-service": {
      "type": "application",
      "root": "apps/dashboard-service",
      "entryFile": "main",
      "sourceRoot": "apps/dashboard-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/dashboard-service/tsconfig.app.json"
      }
    },
    "database": {
      "type": "library",
      "root": "libs/database",
      "entryFile": "index",
      "sourceRoot": "libs/database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/database/tsconfig.lib.json"
      }
    },
    "device-monitoring": {
      "type": "application",
      "root": "apps/device-monitoring",
      "entryFile": "main",
      "sourceRoot": "apps/device-monitoring/src",
      "compilerOptions": {
        "tsConfigPath": "apps/device-monitoring/tsconfig.app.json"
      }
    },
    "kafka": {
      "type": "application",
      "root": "apps/kafka",
      "entryFile": "main",
      "sourceRoot": "apps/kafka/src",
      "compilerOptions": {
        "tsConfigPath": "apps/kafka/tsconfig.app.json"
      }
    }
  }
}